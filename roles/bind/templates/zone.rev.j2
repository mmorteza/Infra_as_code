; Managed by Ansible - do not edit by hand. Changes will be overwritten.
; Reverse zone: {{ item.name }}
$TTL {{ item.ttl }}
@   IN  SOA {{ item.soa_ns }} {{ item.soa_email }} (
        {{ item.serial }}  ; Serial - bump this on every change
        3600               ; Refresh (1h)
        1800               ; Retry (30m)
        604800             ; Expire (1w)
        86400 )            ; Negative cache TTL (1d)

; Name servers
{% for ns in item.ns_records %}
@   IN  NS  {{ ns }}
{% endfor %}

; PTR records
{% for rec in item.ptr_records | default([], true) %}
{{ rec.host }}    IN  PTR {{ rec.name }}
{% endfor %}