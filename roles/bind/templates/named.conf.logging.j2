logging {

    channel default_log {
        file "/var/log/named/default" versions 3 size 20m;
        severity info;
        print-time yes;
        print-category yes;
        print-severity yes;
    };

    channel queries_log {
        file "/var/log/named/query.log" versions 600 size 20m;
        severity info;
        print-time yes;
        print-category yes;
        print-severity yes;
    };

    channel auth_servers_log {
        file "/var/log/named/auth_servers" versions 100 size 20m;
        severity info;
        print-time yes;
        print-category yes;
        print-severity yes;
    };

    channel zone_transfers_log {
        file "/var/log/named/zone_transfers" versions 3 size 20m;
        severity info;
        print-time yes;
        print-category yes;
        print-severity yes;
    };


    category default {
        default_log;
    };

    category queries {
        queries_log;
    };

    category xfer-in {
        zone_transfers_log;
    };

    category xfer-out {
        zone_transfers_log;
    };

    category notify {
        zone_transfers_log;
    };

    category security {
        default_log;
    };

    category resolver {
        default_log;
    };

    category lame-servers {
        default_log;
    };

    category config {
        default_log;
    };
};